# ══════ REQUIRED ══════
# Без этих переменных контейнеры не стартуют.
BOT_TOKEN=                          # токен Telegram-бота от @BotFather
POSTGRES_PASSWORD=changeme          # пароль PostgreSQL (попадает в DATABASE_URL)

# ══════ DATABASE ══════
DATABASE_URL=postgresql+asyncpg://zoo:${POSTGRES_PASSWORD}@postgres:5432/zoo_bot
REDIS_URL=redis://redis:6379/0

# ══════ AI PROVIDERS ══════
# Единый провайдер OpenRouter — chat + vision + транскрипция голоса.
# Без ключа все AI-функции (включая распознавание голоса) выдают «недоступно».
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Основная текстовая модель (консультант по симптомам и т.п.)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Отдельная модель для фото-сценариев (analyze_pet_photo, analyze_food_photo,
# analyze_food_for_pet, compare_two_foods, analyze_medical_test).
# Большинство DeepSeek-моделей не поддерживают image_url — для vision держим
# OpenAI-совместимую модель.
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
# Модель для /audio/transcriptions (голосовые сообщения, OGG/Opus от Telegram).
# Альтернативы: openai/gpt-4o-transcribe (быстрее/дешевле), openai/gpt-4o-mini-transcribe.
OPENROUTER_TRANSCRIBE_MODEL=openai/whisper-1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=                # опционально: для атрибуции в OpenRouter (HTTP-Referer)
OPENROUTER_APP_NAME=zoo_bot         # опционально: X-Title для дашборда OpenRouter

# ══════ FEATURES ══════
BOT_TIMEZONE=Europe/Moscow          # IANA-таймзона для напоминаний и cron-задач worker
WEATHER_API_KEY=                    # опционально, сейчас не используется (wttr.in бесплатный)
ADMIN_IDS=                          # CSV Telegram user-id, напр. ADMIN_IDS=12345,67890
INTERNAL_API_KEY=                   # общий ключ bot/worker -> backend; сгенерировать secrets.token_urlsafe(32)

# ══════ LIMITS ══════
FREE_AI_LIMIT=10                    # AI-запросов в день для free-тарифа
FREE_PET_LIMIT=2                    # макс. питомцев на free-тарифе
AI_MAX_TOKENS_VISION=1600           # max_tokens для vision-запросов
AI_MAX_TOKENS_TEXT=1800             # max_tokens для текстовых AI-запросов

# ══════ PAYMENTS (optional) ══════
# Заполнить для приёма карточных платежей через YooKassa.
# Если пусто — остаётся только Telegram Stars.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
RECEIPT_EMAIL=                      # email для фискальных чеков
PAYMENT_RETURN_URL=                 # куда редиректить пользователя после оплаты

# ══════ LEGAL DOCS ══════
LEGAL_SELLER_NAME=                  # продавец: ИП/самозанятый/ООО
LEGAL_SELLER_INN=                   # ИНН продавца
LEGAL_SUPPORT_CONTACT=              # Telegram поддержки, например @support
LEGAL_SUPPORT_EMAIL=                # email поддержки и privacy-запросов

# ══════ INTERNAL ══════
# В docker-compose выставляется автоматически. Менять только для local dev без compose.
BACKEND_URL=http://backend:8000
